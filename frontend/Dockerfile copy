FROM nginx:1.25-alpine

# 1. ลบคอนฟิกเริ่มต้นทิ้งก่อน
RUN rm /etc/nginx/conf.d/default.conf

# 2. ก๊อปปี้ไฟล์หน้าเว็บ
COPY index.html /usr/share/nginx/html/index.html
COPY logs.html /usr/share/nginx/html/logs.html

# 3. *** จุดสำคัญ *** # เปลี่ยนจาก /etc/nginx/nginx.conf มาเป็น /etc/nginx/conf.d/default.conf
# เพราะ Nginx จะเอาไฟล์ในโฟลเดอร์ conf.d ไปใส่ใน block http { ... } ให้เราเองอัตโนมัติ
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]